# vscode — keep shared workspace recommendations, ignore everything else.
# `!.vscode/` re-includes the directory (your global gitignore excludes it) so
# the negations below can take effect.
!.vscode/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Exclude sourcemaps
*.map

# obsidian
data.json

# Exclude macOS Finder (System Explorer) View States
.DS_Store
