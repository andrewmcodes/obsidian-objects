{
	"name": "obsidian-objects",
	"version": "1.0.0",
	"description": "Schema-driven, object-based note-taking for Obsidian using native Markdown, Properties, and Bases.",
	"main": "main.js",
	"type": "module",
	"prettier": "@andrewmcodes/prettier-config",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"objects",
		"bases",
		"properties"
	],
	"license": "0-BSD",
	"devDependencies": {
		"@andrewmcodes/commitlint-config": "^0.1.2",
		"@andrewmcodes/prettier-config": "^2.0.0",
		"@commitlint/cli": "^21.0.2",
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"prettier": "^3.8.4",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "^3.0.5"
	}
}
