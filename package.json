{
  "name": "obsidian-objects",
  "version": "1.2.0",
  "description": "Schema-driven, object-based note-taking for Obsidian using native Markdown, Properties, and Bases.",
  "main": "main.js",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "prettier": "@andrewmcodes/prettier-config",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "objects",
    "bases",
    "properties"
  ],
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@andrewmcodes/commitlint-config": "^0.1.2",
    "@andrewmcodes/prettier-config": "^2.0.0",
    "@commitlint/cli": "^21.0.2",
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.3",
    "esbuild": "0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "moment": "2.29.4",
    "obsidian": "latest",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
